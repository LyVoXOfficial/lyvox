# Public configuration (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Absolute base URL used for canonical links, SEO metadata and Stripe redirects.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Server-only secrets (never ship to client bundles)
SUPABASE_SERVICE_ROLE_KEY=
# NOTE: apps/web reads NEXT_PUBLIC_SUPABASE_URL. SUPABASE_URL is only consumed by
# standalone maintenance scripts (e.g. scripts/seedCategories.ts), not the web app.
SUPABASE_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_LOOKUP_URL=https://lookups.twilio.com/v2/PhoneNumbers

# Stripe billing (required for /api/billing/* checkout and webhook)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Rate limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional rate limit overrides (fallback defaults are encoded in apps/web/src/lib/rateLimiter.ts)
RATE_LIMIT_OTP_USER_PER_15M=5
RATE_LIMIT_OTP_IP_PER_60M=20
RATE_LIMIT_REPORT_USER_PER_10M=5
RATE_LIMIT_REPORT_IP_PER_24H=50
RATE_LIMIT_ADMIN_PER_MIN=60
RATE_LIMIT_SEARCH_IP_PER_MIN=60

# Informational only (not read at runtime): documents that the admin role is
# sourced from the JWT app_metadata.role claim. See docs/SECURITY_AUDIT.md.
SUPABASE_JWT_ADMIN_ROLE=app_metadata.role

# T18 launch-gate switch. Leave OFF (default) while seed/demo content is an
# intentional showcase. Set to "true" at launch to exclude seeded accounts from
# aggregates / social proof (top sellers, price medians). Does NOT hide or
# de-index seed listings. See docs/todo/T18-seed-switch.md.
EXCLUDE_SEED_FROM_AGGREGATES=false

# Error tracking (Sentry)
# Server-side DSN (secret) — set in Vercel env only
SENTRY_DSN=
# Client-side DSN (public) — can be shared
NEXT_PUBLIC_SENTRY_DSN=

# Analytics (Vercel Speed Insights + Web Analytics)
# Automatically populated by Vercel deployment
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Error tracking / Analytics capability gates (set to "true" to enable)
CAPABILITY_ERROR_TRACKING=false
CAPABILITY_ANALYTICS_INSIGHTS=false
