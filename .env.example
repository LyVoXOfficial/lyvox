# Public configuration (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Absolute base URL used for canonical links, SEO metadata and Stripe redirects.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Server-only secrets (never ship to client bundles)
SUPABASE_SERVICE_ROLE_KEY=
# Production and Vercel previews are private by default. Set false only for production GO;
# preview deployments ignore false and remain closed.
PRODUCTION_ACCESS_GATE_ENABLED=true
# Human-entered preview code. Use 20+ generated characters and share it out of band.
PRODUCTION_ACCESS_CODE=
# Independent high-entropy cookie signing key (32+ bytes; never reuse the access code).
# Rotating this secret immediately revokes every outstanding preview cookie.
PRODUCTION_ACCESS_GATE_SECRET=
# Unlock also stays closed until both Turnstile keys and the Upstash pair are configured.
# NOTE: apps/web reads NEXT_PUBLIC_SUPABASE_URL. SUPABASE_URL is only consumed by
# standalone maintenance scripts (e.g. scripts/seedCategories.ts), not the web app.
SUPABASE_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_LOOKUP_URL=https://lookups.twilio.com/v2/PhoneNumbers

# Stripe billing (required for /api/billing/* checkout and webhook)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_IDENTITY_WEBHOOK_SECRET=

# Bot protection (free Cloudflare Turnstile tier)
TURNSTILE_SECRET_KEY=

# Transactional email (configure at least one provider plus an approved sender)
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=

# Scheduled jobs and translation provider
CRON_SECRET=
TRANSLATION_PROVIDER_URL=
TRANSLATION_PROVIDER_KEY=

# AI moderation (the Supabase Edge Function also needs its own secret)
OPENAI_API_KEY=

# Contract/company-gated dormant adapters
ITSME_CLIENT_ID=
ITSME_CLIENT_SECRET=
ITSME_REDIRECT_URI=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
ESCROW_PROVIDER_API_KEY=
ESCROW_PROVIDER_WEBHOOK_SECRET=
VAPID_PRIVATE_KEY=

# Rate limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional rate limit overrides (fallback defaults are encoded in apps/web/src/lib/rateLimiter.ts)
RATE_LIMIT_OTP_USER_PER_15M=5
RATE_LIMIT_OTP_IP_PER_60M=20
RATE_LIMIT_REPORT_USER_PER_10M=5
RATE_LIMIT_REPORT_IP_PER_24H=50
RATE_LIMIT_ADVERT_CREATE_USER_PER_10M=5
RATE_LIMIT_ADVERT_CREATE_IP_PER_24H=50
RATE_LIMIT_ADVERT_PUBLISH_USER_PER_10M=10
RATE_LIMIT_ADVERT_PUBLISH_IP_PER_24H=100
RATE_LIMIT_ADMIN_PER_MIN=60
RATE_LIMIT_SEARCH_IP_PER_MIN=60

# Informational only (not read at runtime): documents that the admin role is
# sourced from the JWT app_metadata.role claim. See docs/SECURITY_AUDIT.md.
SUPABASE_JWT_ADMIN_ROLE=app_metadata.role

# T18 launch-gate switch. Leave OFF (default) while seed/demo content is an
# intentional showcase. Set to "true" at launch to exclude seeded accounts from
# aggregates / social proof (top sellers, price medians). Does NOT hide or
# de-index seed listings. See docs/todo/T18-seed-switch.md.
EXCLUDE_SEED_FROM_AGGREGATES=false

# Error tracking (Sentry)
# Server-side DSN (secret) — set in Vercel env only
SENTRY_DSN=
# Client-side DSN (public) — can be shared
NEXT_PUBLIC_SENTRY_DSN=

# Analytics (Vercel Speed Insights + Web Analytics)
# Automatically populated by Vercel deployment
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Deploy-time defaults for low-risk capabilities. Sensitive/money/identity
# capabilities ignore env fallback and require an audited runtime setting.
CAPABILITY_PRO_SUBSCRIPTIONS=false
CAPABILITY_PAID_BOOSTS=false
CAPABILITY_STRIPE_IDENTITY=false
CAPABILITY_ITSME=false
CAPABILITY_WHATSAPP_OTP=false
CAPABILITY_SMS_OTP=false
CAPABILITY_PAYMENTS_ESCROW=false
CAPABILITY_DISCOVER_V2=false
CAPABILITY_BOOST_RANKING=false
CAPABILITY_ADVERT_TRANSLATIONS=false
CAPABILITY_WEB_PUSH=false
CAPABILITY_ERROR_TRACKING=false
CAPABILITY_ANALYTICS_INSIGHTS=false
